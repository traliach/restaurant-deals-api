API_PORT=3000
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
JWT_SECRET=replace-with-strong-random-secret

# Stripe (get from dashboard.stripe.com → Developers → API keys)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Yelp Fusion (get from yelp.com/developers → Manage App → API Key)
YELP_API_KEY=your-yelp-api-key-here

# Groq (get from console.groq.com → API Keys → Create API Key)
GROQ_API_KEY=gsk_your-groq-api-key-here
